# .env.example - Environment variables for AWS S3 integration
# Copy this file to .env and fill in your AWS credentials

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name

# Storage options
USE_S3_STORAGE=true
# Set to false to only use local storage (not recommended for production)

# Logging
LOG_LEVEL=INFO

# For Docker deployment, you can pass these as environment variables
# docker run -e AWS_ACCESS_KEY_ID=xxx -e AWS_SECRET_ACCESS_KEY=yyy ...
